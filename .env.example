# Asset Manager starter environment
# Copy this file to .env.local for local development.

# Restrict asset-management API CORS to your asset manager origin in production.
# Example: https://assets.example.com
ORIGIN=http://localhost:3000

# Optional absolute origin for generated upload/file URLs.
# Leave blank to use the current request origin.
ASSETS_PREFIX=

# Usage dashboard labels.
STORAGE_PLAN_LIMIT_BYTES=
STORAGE_PLAN_LABEL=

# Bring-your-own-auth defaults.
# Keep both false while evaluating the starter locally.
ASSET_MANAGER_AUTH_ENABLED=false
ASSET_MANAGER_PROTECT_ASSET_DELIVERY=false

# Provider-neutral auth UI actions.
ASSET_MANAGER_AUTH_PROVIDER_LABEL=Custom auth provider
ASSET_MANAGER_SIGN_IN_URL=
ASSET_MANAGER_SIGN_OUT_URL=
ASSET_MANAGER_ACCOUNT_URL=

# Optional asset delivery domain restrictions.
ASSET_MANAGER_DOMAIN_RESTRICTIONS_ENABLED=false
ASSET_MANAGER_ALLOWED_ASSET_ORIGINS=
ASSET_MANAGER_ALLOW_DIRECT_ASSET_ACCESS=false
ASSET_MANAGER_DOMAIN_SETTINGS_LOCKED=false

# Default copied URL behavior. Valid values: stable, fresh.
ASSET_MANAGER_DEFAULT_COPIED_LINK_TYPE=stable
ASSET_MANAGER_DEFAULT_SNIPPET_URL_TYPE=stable
ASSET_MANAGER_CACHE_BEHAVIOR_SETTINGS_LOCKED=false
